# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://planforge:devpassword123@localhost:5432/planforge?schema=public"

# ─── Redis (cache + BullMQ queue) ───────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── Seed super admin ───────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@planforge.ai"
SUPER_ADMIN_PASSWORD="ChangeMe123!"

# ─── AI provider switch (mock | gemini | groq | ollama) ─────
AI_PROVIDER="mock"
GEMINI_API_KEY=""
GROQ_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# ─── Email (Mailhog locally) ────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="PlanForge AI <no-reply@planforge.ai>"

# ─── Object storage (MinIO locally / S3-compatible) ─────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="planforge"
S3_SECRET_KEY="devpassword123"
S3_BUCKET="planforge"

# ─── Knowledge Hub ──────────────────────────────────────────
YOUTUBE_API_KEY=""

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── API ────────────────────────────────────────────────────
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"
